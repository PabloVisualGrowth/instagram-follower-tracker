{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        },
        {
            "src": "static/**",
            "use": "@vercel/static"
        }
    ],
    "rewrites": [
        {
            "source": "/static/(.*)",
            "destination": "/static/$1"
        },
        {
            "source": "/run-bot",
            "destination": "/api/index.py"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.py"
        }
    ]
}